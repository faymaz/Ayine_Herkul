<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- Başlık -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hakkında"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp" />

        <!-- Uygulama adı -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Herkul"
            android:textColor="@color/color_accent"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Versiyon -->
        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sürüm 1.1.0"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="40dp" />

        <!-- Ayıraç -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginBottom="32dp" />

        <!-- Geliştirici bölümü -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GELİŞTİRİCİ"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fethi Aymaz"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- E-posta -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_secondary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="E-posta"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="faymaz@aymaz.org"
                android:textColor="@color/color_accent"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Proje Sayfası -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_secondary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Proje Sayfası"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvWebsite"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="github.com/faymaz/Ayine_Herkul"
                android:textColor="@color/color_accent"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Ayıraç -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginBottom="32dp" />

        <!-- Ayine.tv bölümü -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AYİNE.TV"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ayine Dijital Çerçeve; namaz vakitlerinde özel seçilmiş ezanlarla ve ilham verici tefekkür levhalarıyla mekanınızı farklılaştıran bir cihazdır."
            android:textColor="@color/text_header"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.5"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvAyine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="www.ayine.tv"
            android:textColor="@color/color_accent"
            android:textSize="14sp"
            android:layout_marginBottom="20dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Yasal not -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bu uygulama Ayine.tv ile herhangi bir ticari veya kurumsal ilişkisi bulunmamaktadır. Sadece açık kaynaklı olarak destek amacıyla geliştirilmiştir."
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:lineSpacingMultiplier="1.5"
            android:gravity="center"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="48dp" />

    </LinearLayout>
</ScrollView>
