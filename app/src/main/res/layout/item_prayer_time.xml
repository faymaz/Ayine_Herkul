<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:paddingStart="4dp"
    android:paddingEnd="4dp">

    <!-- Date column -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:orientation="vertical"
        android:paddingStart="4dp">

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHijri"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_accent"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView android:id="@+id/tvImsak"  android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1.2" android:textColor="@color/text_primary" android:textSize="12sp" android:gravity="center"/>
    <TextView android:id="@+id/tvGunes"  android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1.2" android:textColor="@color/text_secondary" android:textSize="12sp" android:gravity="center"/>
    <TextView android:id="@+id/tvOgle"   android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1.2" android:textColor="@color/text_primary" android:textSize="12sp" android:gravity="center"/>
    <TextView android:id="@+id/tvIkindi" android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1.2" android:textColor="@color/text_primary" android:textSize="12sp" android:gravity="center"/>
    <TextView android:id="@+id/tvAksam"  android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1.2" android:textColor="@color/color_accent" android:textSize="12sp" android:gravity="center"/>
    <TextView android:id="@+id/tvYatsi"  android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1.2" android:textColor="@color/text_primary" android:textSize="12sp" android:gravity="center"/>

</LinearLayout>
