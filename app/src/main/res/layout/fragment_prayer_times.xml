<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_header"
        android:padding="12dp">

        <!-- Country Selector -->
        <Spinner
            android:id="@+id/spinnerCountry"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/bg_spinner"
            android:popupBackground="#FFF5F5F5"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <!-- City Selector -->
        <Spinner
            android:id="@+id/spinnerCity"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/bg_spinner"
            android:popupBackground="#FFF5F5F5"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginTop="6dp" />

        <!-- Dates -->
        <TextView
            android:id="@+id/tvTodayDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvHijriDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_accent"
            android:textSize="14sp"
            android:gravity="center" />

        <!-- Next prayer countdown -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center">

            <TextView
                android:id="@+id/tvNextPrayer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_accent"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="@drawable/bg_countdown"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- View Mode Tabs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="@color/bg_secondary">

        <Button
            android:id="@+id/btnDaily"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Günlük"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_tab_button"
            android:textSize="12sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <Button
            android:id="@+id/btnWeekly"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Haftalık"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_tab_button"
            android:textSize="12sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <Button
            android:id="@+id/btnMonthly"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Aylık"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_tab_button"
            android:textSize="12sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <Button
            android:id="@+id/btnYearly"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Yıllık"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_tab_button"
            android:textSize="12sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />
    </LinearLayout>

    <!-- Column Headers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:orientation="horizontal"
        android:background="@color/bg_table_header"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="2" android:text="Tarih"
            android:textColor="@color/text_header" android:textSize="11sp"
            android:gravity="center_vertical|start" android:paddingStart="4dp"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1.2" android:text="İmsak"
            android:textColor="@color/text_header" android:textSize="11sp" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1.2" android:text="Güneş"
            android:textColor="@color/text_header" android:textSize="11sp" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1.2" android:text="Öğle"
            android:textColor="@color/text_header" android:textSize="11sp" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1.2" android:text="İkindi"
            android:textColor="@color/text_header" android:textSize="11sp" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1.2" android:text="Akşam"
            android:textColor="@color/text_header" android:textSize="11sp" android:gravity="center"/>
        <TextView android:layout_width="0dp" android:layout_height="match_parent"
            android:layout_weight="1.2" android:text="Yatsı"
            android:textColor="@color/text_header" android:textSize="11sp" android:gravity="center"/>
    </LinearLayout>

    <!-- Loading / Error -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FF5555"
        android:textSize="14sp"
        android:padding="16dp"
        android:gravity="center"
        android:visibility="gone" />

    <!-- Prayer Times List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
